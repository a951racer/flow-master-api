# Server port — set automatically by Heroku in production; set manually for local development
PORT=3000

# MongoDB connection string (e.g. MongoDB Atlas URI)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/<dbname>?retryWrites=true&w=majority

# Secret key used to sign and verify JWTs
JWT_SECRET=your_jwt_secret_here

# JWT expiry duration (e.g. "1h", "7d"); defaults to "1h" if not set
JWT_EXPIRES_IN=1h

# Runtime environment: "development" | "production" | "test"
NODE_ENV=development

# Frontend URL for CORS (use * for development to allow all origins, or specify the exact URL)
FRONTEND_URL=http://localhost:3000
